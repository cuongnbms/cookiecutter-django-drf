django: python3 manage.py runserver 0.0.0.0:8000
{% if cookiecutter.use_dramatiq == "y" -%}
worker: watchmedo auto-restart --directory=./ --pattern=*.py --recursive -- python3 manage.py rundramatiq --processes 2 --threads 10 --queues default low high
# scheduler: watchmedo auto-restart --directory=./ --pattern=*.py --recursive -- python3 manage.py run_scheduler
{%- endif %}
